local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
-- เลือก Theme "Serpent" เพราะดูสะอาดตาและไม่กินทรัพยากร
local Window = Library.CreateLib("Driving Empire: Light Hub", "Serpent")

-- สร้าง Tab หลัก
local Main = Window:NewTab("Vehicle")
local Section = Main:NewSection("Engine Mods (Kavo)")

local SpeedValue = 16 -- ค่าความเร็วเริ่มต้น

-- ตัวเลื่อนปรับความเร็ว (Slider)
Section:NewSlider("Custom Max Speed", "ปรับความเร็วรถ (แนะนำ 100-200)", 500, 16, function(s)
    SpeedValue = s
end)

-- ปุ่มเปิด/ปิดความเร็ว (Toggle)
Section:NewToggle("Enable Turbo", "ทำให้รถพุ่งไปข้างหน้าตามค่าที่ตั้งไว้", function(state)
    _G.SpeedHack = state
    task.spawn(function()
        while _G.SpeedHack do
            task.wait(0.1)
            pcall(function()
                local lp = game.Players.LocalPlayer
                local char = lp.Character
                if char and char:FindFirstChild("Humanoid") then
                    local seat = char.Humanoid.SeatPart
                    if seat and seat:IsA("VehicleSeat") then
                        local vehicle = seat.Parent
                        -- เพิ่มแรงพุ่งให้ตัวรถ
                        vehicle.PrimaryPart.Velocity = vehicle.PrimaryPart.CFrame.LookVector * SpeedValue
                    end
                end
            end)
        end
    end)
end)

-- ปุ่มเบรกกะทันหัน (Button)
Section:NewButton("Instant Brake", "หยุดรถทันที (กันรถกระเด็น)", function()
    pcall(function()
        local seat = game.Players.LocalPlayer.Character.Humanoid.SeatPart
        if seat then
            seat.Parent.PrimaryPart.Velocity = Vector3.new(0, 0, 0)
        end
    end)
end)

-- Tab สำหรับตั้งค่าการแสดงผล
local Settings = Window:NewTab("Settings")
local SetSection = Settings:NewSection("UI Settings")

SetSection:NewKeybind("ปิด/เปิด เมนู", "กดปุ่มเพื่อซ่อนหน้าต่าง", Enum.KeyCode.RightControl, function()
	Library:ToggleUI()
end)
