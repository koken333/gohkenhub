local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Driving Empire: Highway Farm", "Serpent")

-- [ Tab: AFK Farm ]
local FarmTab = Window:NewTab("AFK Farm")
local Section = FarmTab:NewSection("Highway Loop (AFK)")

-- พิกัดที่คุณให้มา
local Pos1 = Vector3.new(-1386, 22, -2589)
local Pos2 = Vector3.new(-6742, 30, -2794)

local FarmSpeed = 200 -- ความเร็วแนะนำสำหรับทางหลวง

Section:NewSlider("Farm Speed", "ปรับความเร็ว (แนะนำ 200-250)", 500, 50, function(s)
    FarmSpeed = s
end)

Section:NewToggle("Start Highway Farm", "วิ่งวนลูประหว่าง 2 พิกัด", function(state)
    _G.HighwayFarm = state
    task.spawn(function()
        while _G.HighwayFarm do
            pcall(function()
                local char = game.Players.LocalPlayer.Character
                local seat = char.Humanoid.SeatPart
                if seat and seat:IsA("VehicleSeat") then
                    local car = seat.Parent
                    local root = car.PrimaryPart
                    local targets = {Pos1, Pos2}

                    for _, target in ipairs(targets) do
                        if not _G.HighwayFarm then break end
                        
                        -- วิ่งไปจนกว่าจะถึงจุดหมาย (ระยะห่างน้อยกว่า 50 studs)
                        while (root.Position - target).Magnitude > 50 and _G.HighwayFarm do
                            task.wait()
                            
                            -- หันหน้าไปหาจุดหมาย
                            root.CFrame = CFrame.new(root.Position, Vector3.new(target.X, root.Position.Y, target.Z))
                            
                            -- แรงส่งไปข้างหน้า + แรงกดติดพื้น (กันเหินเวลาลงเนิน)
                            root.Velocity = root.CFrame.LookVector * FarmSpeed + Vector3.new(0, -60, 0)
                            
                            -- ล็อครถไม่ให้คว่ำ
                            root.RotVelocity = Vector3.new(0, 0, 0)
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end)

Section:NewButton("Teleport to Highway", "วาร์ปไปจุดเริ่มทันที", function()
    pcall(function()
        game.Players.LocalPlayer.Character.Humanoid.SeatPart.Parent:SetPrimaryPartCFrame(CFrame.new(Pos1 + Vector3.new(0, 5, 0)))
    end)
end)

-- [ Settings ]
local Settings = Window:NewTab("Settings")
Settings:NewSection("UI Controls"):NewKeybind("Hide Menu", "RightControl เพื่อปิด/เปิด", Enum.KeyCode.RightControl, function()
    Library:ToggleUI()
end)
